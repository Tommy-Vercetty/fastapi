              "pm.test(\"USD to EUR\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"UnitPriceEUR\");",
              "    pm.expect(jsonData.UnitPriceEUR).to.be.a(\"number\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/convert?productID=1005",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["convert"],
          "query": [{ "key": "productID", "value": "1005" }]
        }
      },
