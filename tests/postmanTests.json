  "item": [
    {
      "name": "/",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Root Endpoint Testing",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"API Health Check\", function () {",
              "    pm.response.to.have.status(200);",
              "    pm.response.to.be.success;",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000"
        }
      },
      "response": []
    },
    {
      "name": "/getSingleProduct",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//getSingleProduct Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Product Structure Testing\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"ProductID\");",
              "    pm.expect(jsonData).to.have.property(\"Name\");",
              "    pm.expect(jsonData).to.have.property(\"UnitPrice\");",
              "    pm.expect(jsonData).to.have.property(\"StockQuantity\");",
              "    pm.expect(jsonData).to.have.property(\"Description\");",
              "});",
              "",
              "pm.test(\"ProductID Matches the Request\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.ProductID).to.eql(1005);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/getSingleProduct?productID=1005",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["getSingleProduct"],
          "query": [{ "key": "productID", "value": "1005" }]
        }
      },
      "response": []
    },
    {
      "name": "/getAll",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//getAll Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Returns all products in an array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Testing each product has its required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        pm.expect(jsonData[0]).to.have.property(\"ProductID\");",
              "        pm.expect(jsonData[0]).to.have.property(\"Name\");",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/getAll",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["getAll"]
        }
      },
      "response": []
    },
    {
      "name": "/addNew",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//addNew Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Product Adding testing\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"message\");",
              "    pm.expect(jsonData.message).to.include(\"Product added\");",
              "    pm.expect(jsonData).to.have.property(\"newlyInsertedProductID\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ProductID\": 1010,\n  \"Name\": \"Test Product\",\n  \"UnitPrice\": 19.99,\n  \"StockQuantity\": 50,\n  \"Description\": \"Sample description\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/addNew",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["addNew"]
        }
      },
      "response": []
    },
    {
      "name": "/deleteOne",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//deleteOne Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Delete Product testing\", function () {",
              "    const jsonData = pm.response.json();",
              "    if(jsonData.message){",
              "        pm.expect(jsonData).to.have.property(\"message\");",
              "        pm.expect(jsonData.message).to.include(\"deleted\");",
              "        pm.expect(jsonData).to.have.property(\"numberOfDeletedProducts\");",
              "    } else {",
              "        pm.expect(jsonData).to.have.property(\"error\");",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/deleteOne?productID=1006",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["deleteOne"],
          "query": [{ "key": "productID", "value": "1006" }]
        }
      },
      "response": []
    },
    {
      "name": "/startsWith",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//startsWith Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Products starting with user entered letter testing\", function () {",
              "    const jsonData = pm.response.json();",
              "    const letter = pm.request.url.query.get('userEnteredLetter')?.toLowerCase() || 'a';",
              "    if (Array.isArray(jsonData)) {",
              "        jsonData.forEach(product => { pm.expect(product.Name[0].toLowerCase()).to.eql(letter); });",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/startsWith?userEnteredLetter=a",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["startsWith"],
          "query": [{ "key": "userEnteredLetter", "value": "a" }]
        }
      }
    },
    {
      "name": "/paginate",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//paginate Testing",
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "",
              "pm.test(\"Products are within the selected range testing\", function () {",
              "    const jsonData = pm.response.json();",
              "    if (Array.isArray(jsonData)) {",
              "        jsonData.forEach(product => {",
              "            pm.expect(product.ProductID).to.be.within(1010, 1015);",
              "        });",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/paginate?startOfRangeID=1010&endOfRangeID=1015",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["paginate"],
          "query": [
            { "key": "startOfRangeID", "value": "1010" },
            { "key": "endOfRangeID", "value": "1015" }
          ]
        }
      },
      "response": []
    },
