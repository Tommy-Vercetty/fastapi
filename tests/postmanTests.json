{
  "info": {
    "_postman_id": "201bb3bd-c896-486a-9696-6687ee2ad421",
    "name": "My Collection",
    "description": "### Welcome to Postman! This is your first collection. \n\nCollections are your starting point for building and testing APIs. You can use this one to:\n\n• Group related requests\n• Test your API in real-world scenarios\n• Document and share your requests\n\nUpdate the name and overview whenever you’re ready to make it yours.\n\n[Learn more about Postman Collections.](https://learning.postman.com/docs/collections/collections-overview/)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53657248"
  },
  "item": [
    {
      "name": "/",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Root Endpoint Testing",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"API Health Check\", function () {",
              "    pm.response.to.have.status(200);",
              "    pm.response.to.be.success;",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000"
      }
    },
    {
      "name": "/getSingleProduct",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Product Structure Testing\", function () {",
              "    pm.expect(jsonData).to.have.property(\"ProductID\");",
              "    pm.expect(jsonData).to.have.property(\"Name\");",
              "    pm.expect(jsonData).to.have.property(\"UnitPrice\");",
              "    pm.expect(jsonData).to.have.property(\"StockQuantity\");",
              "    pm.expect(jsonData).to.have.property(\"Description\");",
              "});",
              "pm.test(\"ProductID Matches the Request\", function () {",
              "    pm.expect(jsonData.ProductID).to.eql(1065);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/getSingleProduct?productID=1065"
      }
    },
    {
      "name": "/getAll",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Returns all products in an array\", function () {",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});",
              "pm.test(\"Testing each product has its required fields\", function () {",
              "    if (jsonData.length > 0) {",
              "        pm.expect(jsonData[0]).to.have.property(\"ProductID\");",
              "        pm.expect(jsonData[0]).to.have.property(\"Name\");",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/getAll"
      }
    },
    {
      "name": "/addNew",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Product Adding testing\", function () {",
              "    pm.expect(jsonData).to.have.property(\"message\");",
              "    pm.expect(jsonData.message).to.include(\"Product added\");",
              "    pm.expect(jsonData).to.have.property(\"newlyInsertedProductID\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ProductID\": 1010,\n  \"Name\": \"Test Product\",\n  \"UnitPrice\": 19.99,\n  \"StockQuantity\": 50,\n  \"Description\": \"Sample description\"\n}"
        },
        "url": "http://localhost:8000/addNew"
      }
    },
    {
      "name": "/deleteOne",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Delete Product testing\", function () {",
              "    if(jsonData.message){",
              "        pm.expect(jsonData.message).to.include(\"deleted\");",
              "        pm.expect(jsonData).to.have.property(\"numberOfDeletedProducts\");",
              "    } else {",
              "        pm.expect(jsonData).to.have.property(\"error\");",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/deleteOne?productID=1068"
      }
    },
    {
      "name": "/startsWith",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "const letter = pm.request.url.query.get('userEnteredLetter')?.toLowerCase() || 'a';",
              "if (Array.isArray(jsonData)) {",
              "    jsonData.forEach(product => {",
              "        pm.expect(product.Name[0].toLowerCase()).to.eql(letter);",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/startsWith?userEnteredLetter=a"
      }
    },
    {
      "name": "/paginate",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"Products are within the selected range testing\", function () {",
              "    if (Array.isArray(jsonData)) {",
              "        jsonData.forEach(product => {",
              "            pm.expect(product.ProductID).to.be.within(1019, 1020);",
              "        });",
              "    }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/paginate?startOfRangeID=1019&endOfRangeID=1020"
      }
    },
    {
      "name": "/convert",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "const jsonData = pm.response.json();",
              "pm.test(\"USD to EUR\", function () {",
              "    pm.expect(jsonData).to.have.property(\"UnitPriceEUR\");",
              "    pm.expect(jsonData.UnitPriceEUR).to.be.a(\"number\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "http://localhost:8000/convert?productID=1113"
      }
    }
  ]
}